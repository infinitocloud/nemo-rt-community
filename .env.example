# =============================================================================
# Nemo-RT Community - Environment Variables
# =============================================================================
# Copy to .env and fill in values:  cp .env.example .env

# =============================================================================
# Environment
# =============================================================================
# Set to "prod" or "production" to enforce strict security checks.
# In prod mode the server REFUSES to start without an API_KEY set.
# Use "dev" (or leave unset) for local development with anonymous access.
ENV=prod

# --- Authentication ---
# API key for WebSocket and HTTP endpoints (leave empty to disable auth)
API_KEY=

# --- Rate Limiting ---
# Max concurrent WebSocket connections (0 = unlimited)
MAX_CONNECTIONS=20

# --- CORS / Origin ---
# Allowed origins, comma-separated (empty = allow all)
# Example: https://your-pod.example.com,https://myapp.example.com
ALLOWED_ORIGINS=

# --- Model Config ---
# HuggingFace token for model downloads (needs read access to Qwen/*)
HF_TOKEN=

# TTS speaker ID (default: 50)
SPEAKER_ID=50

# --- LLM Engine (vLLM) ---
# Base URL of the vLLM OpenAI-compatible endpoint
LLM_BASE_URL=http://vllm:8000/v1

# Model id served by vLLM. The compose file uses the same var to launch vLLM,
# so they must match.
LLM_MODEL=Qwen/Qwen3-8B-FP8

# vLLM container tuning
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEM_FRAC=0.6
# VLLM_LOGGING_LEVEL=DEBUG       # uncomment for verbose vLLM logs

# --- LLM Sampling (defaults from the Qwen3 official card, instruct mode) ---
# Max tokens in LLM response (lower = faster, less verbose)
LLM_MAX_TOKENS=256
# Nucleus sampling (lower = more deterministic)
LLM_TOP_P=0.8
# Frequency penalty. 0.0 recomendado en GPUs Blackwell (RTX PRO 6000):
# valores > 0 activan apply_penalties → scatter_add_ que crashea con
# "CUDA unknown error" en el sampler de vLLM (visto 2026-06-07 con
# Qwen3 FP8). Solo subir si tu version de vLLM ya parcheo el path.
LLM_FREQ_PENALTY=0.0

# --- Config persistence ---
# UI/Settings overrides persist here; delete to reset to env defaults.
CONFIG_FILE=data/config.json

# =============================================================================
# Rate Limiting (slowapi, in-memory, per client IP)
# =============================================================================
# Each value uses the format "<count>/<period>" where period =
#   second | minute | hour | day
#
# /health is exempt (orchestrator health checks).
# All limits apply per remote IP (X-Forwarded-For honored from our nginx proxy).
RATE_LIMIT_ENABLED=true

# Default fallback for endpoints without an explicit limit
RATE_LIMIT_DEFAULT=60/minute

# Brute-force protection on auth verification
RATE_LIMIT_AUTH=10/minute

# Config read/write endpoints (/api/config)
RATE_LIMIT_TENANTS=30/minute

# WebSocket connection attempts (post-connect traffic is not rate-limited)
RATE_LIMIT_WS_CONNECT=30/minute
